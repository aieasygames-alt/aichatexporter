{
  "manifest_version": 3,
  "name": "AI Chat Exporter",
  "version": "1.0.0",
  "description": "Export chat conversations from ChatGPT, Claude, Gemini, Grok and DeepSeek to Markdown, JSON, CSV, TXT or PNG",
  "author": "AI Chat Exporter",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "AI Chat Exporter"
  },

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content/i18n.js", "content/common.js", "content/chatgpt.js", "content/injected-ui.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/i18n.js", "content/common.js", "content/claude.js", "content/injected-ui.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/i18n.js", "content/common.js", "content/gemini.js", "content/injected-ui.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "https://grok.x.com/*",
        "https://x.ai/*",
        "https://www.x.ai/*",
        "https://grok.com/*"
      ],
      "js": ["content/i18n.js", "content/common.js", "content/grok.js", "content/injected-ui.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*"
      ],
      "js": ["content/i18n.js", "content/common.js", "content/deepseek.js", "content/injected-ui.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open AI Chat Exporter popup"
    },
    "export_markdown": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Export current chat as Markdown"
    }
  },

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.x.com/*",
    "https://x.ai/*",
    "https://www.x.ai/*",
    "https://grok.com/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*"
  ]
}
