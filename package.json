{
  "name": "ai-chat-exporter",
  "version": "1.0.0",
  "description": "Export chat conversations from AI platforms to multiple formats",
  "type": "module",
  "scripts": {
    "dev": "npx vite build --watch --mode development",
    "build": "npx tsc --noEmit && npx vite build",
    "preview": "npx vite preview",
    "type-check": "npx tsc --noEmit",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "npx prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage"
  },
  "keywords": [
    "chrome-extension",
    "chatgpt",
    "claude",
    "gemini",
    "grok",
    "deepseek",
    "export",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.0",
    "terser": "^5.46.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  }
}
