---
import { type Lang, useTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const productLinks = [
  { href: `/${lang}/features`, label: t('footer.features') },
  { href: `/${lang}/how-to-use`, label: t('footer.howToUse') },
  { href: `/${lang}/platforms`, label: t('nav.platforms') },
  { href: `/${lang}/faq`, label: t('footer.faq') },
];

const resourceLinks = [
  { href: `/${lang}/tips`, label: t('nav.tips') },
  { href: `/${lang}/markdown-to-pdf`, label: 'Markdown to PDF' },
  { href: '#', label: t('footer.documentation') },
  { href: '#', label: t('footer.changelog') },
  { href: '#', label: t('footer.support') },
];

const legalLinks = [
  { href: `/${lang}/privacy`, label: t('footer.privacy') },
];
---

<footer class="bg-bg-secondary border-t border-white/5">
  <div class="container-custom py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href={`/${lang}`} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-chatgpt flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
          </div>
          <span class="font-semibold text-white">AI Chat Exporter</span>
        </a>
        <p class="text-sm text-gray-500 mb-4">
          Export your AI conversations with one click.
        </p>
        <!-- Social Links -->
        <div class="flex gap-4">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-semibold text-white mb-4">{t('footer.product')}</h4>
        <ul class="space-y-2">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-white mb-4">{t('footer.resources')}</h4>
        <ul class="space-y-2">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-semibold text-white mb-4">{t('footer.legal')}</h4>
        <ul class="space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-white/5">
      <p class="text-sm text-gray-500 text-center">
        {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
