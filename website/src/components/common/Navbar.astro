---
import { type Lang, useTranslations, languages, getRouteFromUrl } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentPath = getRouteFromUrl(Astro.url);

const navLinks = [
  { href: `/${lang}`, label: t('nav.home') },
  { href: `/${lang}/features`, label: t('nav.features') },
  { href: `/${lang}/how-to-use`, label: t('nav.howToUse') },
  { href: `/${lang}/faq`, label: t('nav.faq') },
];

const toolLinks = [
  { href: `/${lang}/markdown-to-pdf`, label: t('tools.markdownToPdf'), icon: 'pdf' },
  { href: `/${lang}/json-to-markdown`, label: t('tools.jsonToMarkdown'), icon: 'json' },
  { href: `/${lang}/code-to-pdf`, label: t('tools.codeToPdf'), icon: 'code' },
  { href: `/${lang}/diff-checker`, label: t('tools.diffChecker'), icon: 'diff' },
  { href: `/${lang}/html-to-markdown`, label: t('tools.htmlToMarkdown'), icon: 'html' },
  { href: `/${lang}/csv-to-json`, label: t('tools.csvToJson'), icon: 'csv' },
  { href: `/${lang}/markdown-table`, label: t('tools.markdownTable'), icon: 'table' },
  { href: `/${lang}/text-case`, label: t('tools.textCase'), icon: 'case' },
  { href: `/${lang}/url-encoder`, label: t('tools.urlEncoder'), icon: 'url' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-lg border-b border-white/5">
  <div class="container-custom">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`/${lang}`} class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-chatgpt flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
        </div>
        <span class="font-semibold text-white group-hover:text-accent transition-colors">AI Chat Exporter</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-accent',
              currentPath === '/' && link.href === `/${lang}` || currentPath !== '/' && link.href.includes(currentPath)
                ? 'text-accent'
                : 'text-gray-400'
            ]}
          >
            {link.label}
          </a>
        ))}

        <!-- Tools Dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm font-medium transition-colors hover:text-accent text-gray-400">
            {t('nav.tools')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Tools Dropdown Menu -->
          <div class="absolute left-0 top-full mt-2 py-2 w-56 bg-bg-secondary rounded-xl border border-white/10 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {toolLinks.map((tool) => (
              <a
                href={tool.href}
                class="flex items-center gap-3 px-4 py-2 text-sm text-gray-400 hover:text-white hover:bg-white/5 transition-colors"
              >
                <span class="w-6 h-6 rounded bg-white/5 flex items-center justify-center text-xs">
                  {tool.icon === 'pdf' && '📄'}
                  {tool.icon === 'json' && '📋'}
                  {tool.icon === 'code' && '💻'}
                  {tool.icon === 'diff' && '⚖️'}
                  {tool.icon === 'html' && '🌐'}
                  {tool.icon === 'csv' && '📊'}
                  {tool.icon === 'table' && '📝'}
                  {tool.icon === 'case' && 'Aa'}
                  {tool.icon === 'url' && '🔗'}
                </span>
                {tool.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-4">
        <!-- Language Switcher -->
        <div class="relative group">
          <button class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors px-3 py-2 rounded-lg hover:bg-white/5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
            <span>{languages[lang]}</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div class="absolute right-0 top-full mt-1 py-2 w-40 bg-bg-secondary rounded-xl border border-white/10 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={`/${code}${currentPath === '/' ? '' : currentPath}`}
                class:list={[
                  'block px-4 py-2 text-sm transition-colors',
                  code === lang ? 'text-accent bg-accent/10' : 'text-gray-400 hover:text-white hover:bg-white/5'
                ]}
              >
                {name}
              </a>
            ))}
          </div>
        </div>

        <!-- Install Button -->
        <a
          href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm hidden sm:flex"
        >
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {t('nav.install')}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-gray-400 hover:text-white transition-colors"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-bg-secondary border-t border-white/5">
    <div class="container-custom py-4 space-y-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-2 rounded-lg text-sm font-medium transition-colors',
            currentPath === '/' && link.href === `/${lang}` || currentPath !== '/' && link.href.includes(currentPath)
              ? 'text-accent bg-accent/10'
              : 'text-gray-400 hover:text-white hover:bg-white/5'
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- Tools Section in Mobile -->
      <div class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
        {t('nav.tools')}
      </div>
      {toolLinks.map((tool) => (
        <a
          href={tool.href}
          class="flex items-center gap-3 px-4 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-white/5 transition-colors"
        >
          <span class="w-5 h-5 rounded bg-white/5 flex items-center justify-center text-xs">
            {tool.icon === 'pdf' && '📄'}
            {tool.icon === 'json' && '📋'}
            {tool.icon === 'code' && '💻'}
            {tool.icon === 'diff' && '⚖️'}
            {tool.icon === 'html' && '🌐'}
            {tool.icon === 'csv' && '📊'}
            {tool.icon === 'table' && '📝'}
            {tool.icon === 'case' && 'Aa'}
            {tool.icon === 'url' && '🔗'}
          </span>
          {tool.label}
        </a>
      ))}

      <a
        href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-sm w-full mt-4"
      >
        {t('nav.install')}
      </a>
    </div>
  </div>
</nav>

<!-- Spacer for fixed navbar -->
<div class="h-16"></div>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
