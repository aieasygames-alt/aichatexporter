---
import { type Lang, useTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const platforms = [
  { name: 'ChatGPT', logo: '/assets/platforms/chatgpt', color: 'chatgpt' },
  { name: 'Claude', logo: '/assets/platforms/claude', color: 'claude' },
  { name: 'Gemini', logo: '/assets/platforms/gemini', color: 'gemini' },
  { name: 'DeepSeek', logo: '/assets/platforms/deepseek', color: 'deepseek' },
  { name: 'Grok', logo: '/assets/platforms/grok', color: 'grok' },
];
---

<section class="relative overflow-hidden py-20 lg:py-32">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent pointer-events-none"></div>

  <div class="container-custom relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div class="text-center lg:text-left">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 text-balance">
          <span class="gradient-text">{t('hero.title')}</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-400 mb-8 max-w-2xl mx-auto lg:mx-0">
          {t('hero.subtitle')}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-12">
          <a
            href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-lg px-8 py-4"
          >
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            {t('hero.cta.install')}
          </a>
          <a href={`/${lang}/features`} class="btn-secondary text-lg px-8 py-4">
            {t('hero.cta.learnMore')}
          </a>
        </div>

        <!-- Platform logos -->
        <div class="mb-4">
          <p class="text-sm text-gray-500 mb-4">{t('hero.platforms')}</p>
          <div class="flex items-center justify-center lg:justify-start gap-4 flex-wrap">
            {platforms.map((platform) => (
              <div
                class="w-12 h-12 rounded-xl bg-bg-secondary border border-white/5 flex items-center justify-center hover:border-white/20 transition-colors"
                title={platform.name}
              >
                <picture>
                  <source srcset={`${platform.logo}.webp`} type="image/webp" />
                  <img
                    src={`${platform.logo}.png`}
                    alt={platform.name}
                    class="w-8 h-8 object-contain"
                    loading="lazy"
                    width="32"
                    height="32"
                  />
                </picture>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Demo Video -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="relative animate-float">
          <!-- Glow effect -->
          <div class="absolute -inset-4 bg-gradient-to-r from-accent/20 via-chatgpt/20 to-claude/20 blur-3xl opacity-50"></div>

          <!-- Video Demo -->
          <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl bg-bg-secondary">
            <video
              class="w-full max-w-lg"
              autoplay
              loop
              muted
              playsinline
              width="512"
              height="384"
            >
              <source src="/assets/videos/demo.webm" type="video/webm" />
              <source src="/assets/videos/demo.mp4" type="video/mp4" />
              <!-- Fallback to screenshot if video not supported -->
              <picture>
                <source srcset="/assets/screenshots/hero-screenshot.webp" type="image/webp" />
                <img
                  src="/assets/screenshots/hero-screenshot.png"
                  alt="AI Chat Exporter Screenshot"
                  class="w-full max-w-lg"
                  loading="eager"
                  width="512"
                  height="384"
                />
              </picture>
            </video>

            <!-- Video controls overlay -->
            <div class="absolute bottom-3 right-3 flex items-center gap-2 bg-black/50 backdrop-blur-sm rounded-lg px-3 py-1.5">
              <span class="text-xs text-white/70">Demo</span>
              <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
