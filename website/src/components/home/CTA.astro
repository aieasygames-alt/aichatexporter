---
import { type Lang, useTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-r from-accent/10 via-chatgpt/10 to-claude/10"></div>

  <div class="container-custom relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-white">
        {t('cta.title')}
      </h2>
      <p class="text-lg text-gray-400 mb-8">
        {t('cta.subtitle')}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-lg px-8 py-4 inline-flex items-center justify-center"
        >
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {t('cta.button')}
        </a>
      </div>

      {/* Trust indicators */}
      <div class="mt-8 flex items-center justify-center gap-6 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>100% Free</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>No Account Required</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Privacy First</span>
        </div>
      </div>
    </div>
  </div>
</section>
