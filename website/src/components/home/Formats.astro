---
import { type Lang, useTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const formats = [
  { name: 'Markdown', ext: '.md', icon: '/assets/formats/md', color: 'bg-blue-500/10 border-blue-500/30' },
  { name: 'JSON', ext: '.json', icon: '/assets/formats/json', color: 'bg-yellow-500/10 border-yellow-500/30' },
  { name: 'PDF', ext: '.pdf', icon: '/assets/formats/pdf', color: 'bg-red-500/10 border-red-500/30' },
  { name: 'TXT', ext: '.txt', icon: '/assets/formats/txt', color: 'bg-gray-500/10 border-gray-500/30' },
  { name: 'CSV', ext: '.csv', icon: '/assets/formats/csv', color: 'bg-green-500/10 border-green-500/30' },
  { name: 'PNG', ext: '.png', icon: '/assets/formats/png', color: 'bg-purple-500/10 border-purple-500/30' },
];
---

<section class="py-20">
  <div class="container-custom">
    <h2 class="section-title">{t('formats.title')}</h2>
    <p class="section-subtitle">{t('formats.subtitle')}</p>

    <div class="flex flex-wrap justify-center gap-4">
      {formats.map((format) => (
        <div
          class={`flex items-center gap-3 px-5 py-3 rounded-xl border ${format.color} hover:scale-105 transition-transform duration-300`}
        >
          <picture>
            <source srcset={`${format.icon}.webp`} type="image/webp" />
            <img
              src={`${format.icon}.png`}
              alt={format.name}
              class="w-8 h-8 object-contain"
              loading="lazy"
              width="32"
              height="32"
            />
          </picture>
          <div>
            <div class="text-sm font-medium text-white">{format.name}</div>
            <div class="text-xs text-gray-500">{format.ext}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
