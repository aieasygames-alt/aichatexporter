---
import { type Lang, useTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  {
    key: 'exportFormats',
    icon: '/assets/icons/export.png',
    color: 'accent',
  },
  {
    key: 'privacy',
    icon: '/assets/icons/privacy.png',
    color: 'chatgpt',
  },
  {
    key: 'multiLanguage',
    icon: '/assets/icons/language.png',
    color: 'claude',
  },
  {
    key: 'oneClick',
    icon: '/assets/icons/fast.png',
    color: 'grok',
  },
];
---

<section class="py-20 bg-bg-secondary/50">
  <div class="container-custom">
    <h2 class="section-title">{t('features.title')}</h2>
    <p class="section-subtitle">{t('features.subtitle')}</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <div
          class="card card-hover group"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class={`w-16 h-16 rounded-xl bg-${feature.color}/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
            <img
              src={feature.icon}
              alt={t(`features.${feature.key}.title`)}
              class="w-10 h-10 object-contain"
              loading="lazy"
            />
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">
            {t(`features.${feature.key}.title`)}
          </h3>
          <p class="text-gray-400 text-sm">
            {t(`features.${feature.key}.description`)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
