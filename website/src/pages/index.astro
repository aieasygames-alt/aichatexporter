---
// 静态生成模式下，使用客户端 JavaScript 进行语言检测和重定向
// 支持的语言列表
const supportedLangs = ['zh-CN', 'en', 'ja', 'ko', 'es', 'fr'];
const defaultLang = 'en';
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Chat Exporter</title>
  <script is:inline>
    (function() {
      // 支持的语言
      var supportedLangs = ['zh-CN', 'en', 'ja', 'ko', 'es', 'fr'];
      var defaultLang = 'en';

      // 获取浏览器语言
      var browserLang = navigator.language || navigator.userLanguage;

      // 匹配语言
      var targetLang = defaultLang;

      // 完全匹配
      if (supportedLangs.indexOf(browserLang) !== -1) {
        targetLang = browserLang;
      } else {
        // 部分匹配（如 zh 匹配 zh-CN）
        var langPrefix = browserLang.split('-')[0];
        for (var i = 0; i < supportedLangs.length; i++) {
          if (supportedLangs[i].indexOf(langPrefix) === 0) {
            targetLang = supportedLangs[i];
            break;
          }
        }
      }

      // 检查是否已经访问过（避免重复重定向）
      var hasVisited = sessionStorage.getItem('lang-detected');

      if (!hasVisited) {
        sessionStorage.setItem('lang-detected', 'true');
        // 直接跳转，无需等待
        window.location.replace('/' + targetLang + '/');
      } else {
        // 已访问过，默认跳转英文
        window.location.replace('/' + defaultLang + '/');
      }
    })();
  </script>
  <noscript>
    <meta http-equiv="refresh" content="0;url=/en/">
  </noscript>
</head>
<body>
  <p style="text-align:center;padding-top:100px;font-family:sans-serif;">Redirecting...</p>
</body>
</html>
