---
import { languages } from '../i18n';

// 获取浏览器首选语言
const acceptLanguage = Astro.request.headers.get('accept-language') || '';

// 解析浏览器语言偏好
function getPreferredLanguage(acceptLang: string): string {
  // 解析 Accept-Language 头，格式如: "zh-CN,zh;q=0.9,en;q=0.8"
  const languages = acceptLang.split(',').map(lang => {
    const [code, q] = lang.trim().split(';q=');
    return { code: code.toLowerCase(), weight: q ? parseFloat(q) : 1 };
  });

  // 按权重排序
  languages.sort((a, b) => b.weight - a.weight);

  // 匹配支持的语言
  const supportedLangs = ['zh-cn', 'en', 'ja', 'ko', 'es', 'fr'];

  for (const lang of languages) {
    // 完全匹配
    if (supportedLangs.includes(lang.code)) {
      return lang.code === 'zh-cn' ? 'zh-CN' : lang.code;
    }
    // 部分匹配（如 zh 匹配 zh-CN）
    const partialMatch = supportedLangs.find(s => s.startsWith(lang.code.split('-')[0]));
    if (partialMatch) {
      return partialMatch === 'zh-cn' ? 'zh-CN' : partialMatch;
    }
  }

  // 默认英文
  return 'en';
}

const preferredLang = getPreferredLanguage(acceptLanguage);
return Astro.redirect(`/${preferredLang}`);
---
