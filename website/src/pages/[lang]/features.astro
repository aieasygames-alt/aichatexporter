---
import Layout from '../../layouts/Layout.astro';
import { type Lang, useTranslations, languages } from '../../i18n';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const features = [
  {
    key: 'exportFormats',
    icon: '/assets/icons/export.png',
    details: [
      'Markdown (.md) - Perfect for documentation and note-taking apps',
      'JSON - Structured data for developers and automation',
      'PDF - Professional documents with formatting preserved',
      'TXT - Plain text for maximum compatibility',
      'CSV - Spreadsheet format for data analysis',
      'PNG Image - Styled screenshots perfect for sharing',
    ],
  },
  {
    key: 'privacy',
    icon: '/assets/icons/privacy.png',
    details: [
      'All processing happens locally in your browser',
      'No data is ever sent to external servers',
      'No account or registration required',
      'Open source code for full transparency',
    ],
  },
  {
    key: 'multiLanguage',
    icon: '/assets/icons/language.png',
    details: [
      'English - Full support',
      '简体中文 - 完整支持',
      '日本語 - 完全対応',
      '한국어 - 완전 지원',
      'Español - Soporte completo',
      'Français - Support complet',
    ],
  },
  {
    key: 'oneClick',
    icon: '/assets/icons/fast.png',
    details: [
      'Floating popup appears on supported AI platforms',
      'One-click access from browser toolbar',
      'Intuitive interface with clear options',
      'Instant export with no configuration needed',
    ],
  },
];

const platforms = [
  { name: 'ChatGPT', logo: '/assets/platforms/chatgpt.png', url: 'https://chat.openai.com' },
  { name: 'Claude', logo: '/assets/platforms/claude.png', url: 'https://claude.ai' },
  { name: 'Gemini', logo: '/assets/platforms/gemini.png', url: 'https://gemini.google.com' },
  { name: 'DeepSeek', logo: '/assets/platforms/deepseek.png', url: 'https://chat.deepseek.com' },
  { name: 'Grok', logo: '/assets/platforms/grok.png', url: 'https://grok.x.com' },
];
---

<Layout
  title={`${t('nav.features')} - AI Chat Exporter`}
  description={t('site.description')}
  lang={lang}
>
  <!-- Hero -->
  <section class="py-20 text-center">
    <div class="container-custom">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">
        <span class="gradient-text">{t('features.title')}</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        {t('features.subtitle')}
      </p>
    </div>
  </section>

  <!-- Features Detail -->
  <section class="py-12">
    <div class="container-custom">
      {features.map((feature, index) => (
        <div class:list={['grid lg:grid-cols-2 gap-12 items-center mb-24', index % 2 === 1 && 'lg:flex-row-reverse']}>
          <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-xl bg-accent/10 flex items-center justify-center">
                <img src={feature.icon} alt="" class="w-10 h-10 object-contain" />
              </div>
              <h2 class="text-2xl font-bold text-white">
                {t(`features.${feature.key}.title`)}
              </h2>
            </div>
            <p class="text-gray-400 mb-6">
              {t(`features.${feature.key}.description`)}
            </p>
            <ul class="space-y-3">
              {feature.details.map((detail) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-300">{detail}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
            <div class="bg-bg-secondary rounded-2xl p-8 border border-white/5">
              <img
                src="/assets/screenshots/hero-screenshot.png"
                alt={t(`features.${feature.key}.title`)}
                class="w-full rounded-xl"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Supported Platforms -->
  <section class="py-20 bg-bg-secondary/50">
    <div class="container-custom text-center">
      <h2 class="text-3xl font-bold mb-4">Supported Platforms</h2>
      <p class="text-gray-400 mb-12">Works seamlessly with all major AI chat platforms</p>

      <div class="flex flex-wrap justify-center gap-6">
        {platforms.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-6 py-4 bg-bg-primary rounded-xl border border-white/5 hover:border-accent/50 transition-colors"
          >
            <img src={platform.logo} alt={platform.name} class="w-10 h-10 object-contain" />
            <span class="font-medium text-white">{platform.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="container-custom text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
      <p class="text-gray-400 mb-8">Install AI Chat Exporter now and start exporting your AI conversations.</p>
      <a
        href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-lg px-8 py-4"
      >
        Install Free Extension
      </a>
    </div>
  </section>
</Layout>
