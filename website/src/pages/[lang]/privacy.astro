---
import Layout from '../../layouts/Layout.astro';
import { type Lang, useTranslations, languages } from '../../i18n';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const lastUpdated = 'March 5, 2024';
---

<Layout
  title={`${t('footer.privacy')} - AI Chat Exporter`}
  description="Privacy Policy for AI Chat Exporter. Learn how we handle and protect your data."
  lang={lang}
>
  <article class="py-20">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <header class="mb-12 text-center">
          <h1 class="text-4xl font-bold mb-4 gradient-text">{t('footer.privacy')}</h1>
          <p class="text-gray-400">Last updated: {lastUpdated}</p>
        </header>

        <!-- Content -->
        <div class="prose prose-invert max-w-none">
          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Introduction</h2>
            <p class="text-gray-400 leading-relaxed">
              AI Chat Exporter ("we", "our", or "the extension") is committed to protecting your privacy.
              This privacy policy explains how our browser extension handles information when you use it.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Data Collection</h2>
            <div class="bg-green-500/10 border border-green-500/20 rounded-xl p-4 mb-4">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <h3 class="font-semibold text-green-400 mb-1">We collect NO data</h3>
                  <p class="text-gray-400 text-sm">
                    AI Chat Exporter does not collect, store, transmit, or share any of your personal data or conversations.
                  </p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 leading-relaxed">
              All processing happens entirely within your browser. Your AI conversations are never sent to any external servers,
              including our own. The extension functions completely offline after installation.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">How The Extension Works</h2>
            <ul class="space-y-3 text-gray-400">
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-bold flex-shrink-0">1</span>
                <span>The extension reads conversation content directly from the web page you're viewing</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-bold flex-shrink-0">2</span>
                <span>It converts the content to your chosen format (Markdown, JSON, PDF, etc.)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-bold flex-shrink-0">3</span>
                <span>The converted file is downloaded directly to your computer</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-bold flex-shrink-0">4</span>
                <span>No data ever leaves your browser</span>
              </li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Permissions</h2>
            <p class="text-gray-400 leading-relaxed mb-4">
              The extension requires the following browser permissions:
            </p>
            <div class="space-y-4">
              <div class="bg-bg-secondary rounded-xl p-4 border border-white/5">
                <h3 class="font-semibold text-white mb-2">activeTab</h3>
                <p class="text-gray-400 text-sm">
                  Allows the extension to access the content of the current tab when you click the extension icon.
                  This is necessary to read the conversation from the AI chat page.
                </p>
              </div>
              <div class="bg-bg-secondary rounded-xl p-4 border border-white/5">
                <h3 class="font-semibold text-white mb-2">scripting</h3>
                <p class="text-gray-400 text-sm">
                  Allows the extension to inject scripts into supported AI platforms to extract conversation content.
                </p>
              </div>
              <div class="bg-bg-secondary rounded-xl p-4 border border-white/5">
                <h3 class="font-semibold text-white mb-2">downloads</h3>
                <p class="text-gray-400 text-sm">
                  Allows the extension to save exported files to your computer.
                </p>
              </div>
            </div>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Third-Party Services</h2>
            <p class="text-gray-400 leading-relaxed">
              AI Chat Exporter does not integrate with any third-party services, analytics tools, or advertising networks.
              The extension works entirely independently without any external connections.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Open Source</h2>
            <p class="text-gray-400 leading-relaxed">
              AI Chat Exporter is open source software. You can review the complete source code on our
              <a href="https://github.com" class="text-accent hover:text-accent/80 transition-colors">GitHub repository</a>
              to verify our privacy claims and understand exactly how the extension works.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Changes to This Policy</h2>
            <p class="text-gray-400 leading-relaxed">
              We may update this privacy policy from time to time. Any changes will be posted on this page with an updated revision date.
              We encourage you to review this policy periodically.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-bold text-white mb-4">Contact</h2>
            <p class="text-gray-400 leading-relaxed">
              If you have any questions about this privacy policy or our practices, you may contact us through:
            </p>
            <ul class="mt-4 space-y-2 text-gray-400">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
                <a href="https://github.com" class="text-accent hover:text-accent/80 transition-colors">GitHub</a>
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
                <a href="https://twitter.com" class="text-accent hover:text-accent/80 transition-colors">Twitter/X</a>
              </li>
            </ul>
          </section>
        </div>
      </div>
    </div>
  </article>
</Layout>
