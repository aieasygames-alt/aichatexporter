---
import { type Lang, useTranslations, languages } from '../../i18n';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/common/Navbar.astro';
import Footer from '../../components/common/Footer.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

interface Props {
  lang: Lang;
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const platform = {
  name: 'ChatGPT',
  logo: 'https://upload.wikimedia.org/wikipedia/commons/0/04/ChatGPT_logo.svg',
  color: '#10a37f',
  features: [
    { title: t('platformExport.features.exportAll'), desc: t('platformExport.features.exportAllDesc') },
    { title: t('platformExport.features.multipleFormats'), desc: t('platformExport.features.multipleFormatsDesc') },
    { title: t('platformExport.features.codeHighlight'), desc: t('platformExport.features.codeHighlightDesc') },
    { title: t('platformExport.features.preserveImages'), desc: t('platformExport.features.preserveImagesDesc') },
  ],
  steps: [
    { num: 1, title: t('platformExport.steps.install'), desc: t('platformExport.steps.installDesc') },
    { num: 2, title: t('platformExport.steps.open'), desc: t('chatgptExport.steps.openDesc') },
    { num: 3, title: t('platformExport.steps.click'), desc: t('platformExport.steps.clickDesc') },
    { num: 4, title: t('platformExport.steps.choose'), desc: t('platformExport.steps.chooseDesc') },
  ],
  formats: ['Markdown', 'JSON', 'PDF', 'TXT', 'CSV', 'PNG'],
};
---

<Layout title={t('chatgptExport.title')} description={t('chatgptExport.description')}>
  <Navbar lang={lang} />

  <!-- Hero Section -->
  <section class="py-20 px-4">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <div class="flex-1">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#10a37f]/10 text-[#10a37f] text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364l2.0201-1.1638a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/>
            </svg>
            ChatGPT
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
            {t('chatgptExport.h1')}
          </h1>
          <p class="text-xl text-gray-400 mb-8">
            {t('chatgptExport.subtitle')}
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder" target="_blank" rel="noopener" class="btn-primary">
              {t('chatgptExport.install')}
            </a>
            <a href={`/${lang}/how-to-use`} class="btn-secondary">
              {t('chatgptExport.learnMore')}
            </a>
          </div>
        </div>
        <div class="flex-1">
          <div class="relative">
            <div class="absolute inset-0 bg-[#10a37f]/20 blur-3xl rounded-full"></div>
            <div class="relative bg-bg-secondary rounded-2xl border border-white/10 p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-sm text-gray-500 ml-2">ChatGPT</span>
              </div>
              <div class="space-y-4">
                <div class="p-4 bg-white/5 rounded-lg">
                  <p class="text-sm text-gray-400 mb-2">{t('chatgptExport.demoQuestion')}</p>
                  <p class="text-white">{t('chatgptExport.demoAnswer')}</p>
                </div>
                <div class="flex items-center gap-2 text-sm text-gray-500">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                  </svg>
                  {t('chatgptExport.exporting')}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Export Formats -->
  <section class="py-16 px-4 bg-bg-secondary/50">
    <div class="container-custom">
      <h2 class="text-2xl font-bold text-white text-center mb-8">{t('chatgptExport.formatsTitle')}</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {platform.formats.map((format) => (
          <div class="px-6 py-3 bg-white/5 rounded-lg border border-white/10 text-white font-medium">
            {format}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="py-20 px-4">
    <div class="container-custom">
      <h2 class="text-3xl font-bold text-white text-center mb-12">{t('chatgptExport.stepsTitle')}</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {platform.steps.map((step) => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-[#10a37f]/20 text-[#10a37f] flex items-center justify-center text-xl font-bold mx-auto mb-4">
              {step.num}
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">{step.title}</h3>
            <p class="text-gray-400 text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-4 bg-bg-secondary/50">
    <div class="container-custom">
      <h2 class="text-3xl font-bold text-white text-center mb-12">{t('chatgptExport.featuresTitle')}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {platform.features.map((feature) => (
          <div class="p-6 bg-bg-primary rounded-xl border border-white/5">
            <h3 class="text-lg font-semibold text-white mb-2">{feature.title}</h3>
            <p class="text-gray-400 text-sm">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4">
    <div class="container-custom">
      <div class="bg-gradient-to-r from-[#10a37f]/20 to-[#10a37f]/5 rounded-2xl p-12 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">{t('chatgptExport.ctaTitle')}</h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">{t('chatgptExport.ctaDesc')}</p>
        <a href="https://chromewebstore.google.com/detail/ai-chat-exporter/placeholder" target="_blank" rel="noopener" class="btn-primary inline-flex">
          {t('chatgptExport.ctaButton')}
        </a>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
