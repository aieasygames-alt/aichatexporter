---
import Layout from '../../layouts/Layout.astro';
import { type Lang, useTranslations, languages } from '../../i18n';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const faqCategories = [
  {
    title: 'Getting Started',
    questions: [
      {
        question: t('faq.items.2.question'), // How to install
        answer: t('faq.items.2.answer'),
      },
      {
        question: t('faq.items.4.question'), // Is it free
        answer: t('faq.items.4.answer'),
      },
    ],
  },
  {
    title: 'Features',
    questions: [
      {
        question: t('faq.items.0.question'), // Supported platforms
        answer: t('faq.items.0.answer'),
      },
      {
        question: t('faq.items.3.question'), // Export formats
        answer: t('faq.items.3.answer'),
      },
    ],
  },
  {
    title: 'Privacy & Security',
    questions: [
      {
        question: t('faq.items.1.question'), // Data security
        answer: t('faq.items.1.answer'),
      },
    ],
  },
  {
    title: 'Technical',
    questions: [
      {
        question: t('faq.items.5.question'), // Mobile support
        answer: t('faq.items.5.answer'),
      },
    ],
  },
];

// Additional FAQs
const additionalFAQs = [
  {
    question: 'Can I export conversations from multiple AI chats at once?',
    answer: 'Currently, you need to export each conversation individually. Batch export is a feature we\'re considering for future updates.',
  },
  {
    question: 'Does the extension work in incognito/private mode?',
    answer: 'Yes! You need to enable "Allow in incognito" in the extension settings for it to work in private browsing mode.',
  },
  {
    question: 'Will exported conversations include images and code blocks?',
    answer: 'Yes, all content including images, code blocks, and formatted text is preserved in the export. The level of formatting preservation depends on the chosen export format.',
  },
  {
    question: 'Can I customize the appearance of PNG exports?',
    answer: 'We offer several pre-built themes for PNG exports. Custom themes and color schemes are planned for future updates.',
  },
  {
    question: 'Is there a limit to how many messages I can export?',
    answer: 'There is no hard limit. However, very long conversations may take longer to process and export. PNG format has a practical limit due to browser memory constraints.',
  },
  {
    question: 'How do I report bugs or request features?',
    answer: 'You can report bugs and request features through our GitHub repository or by contacting us on Twitter/X. We appreciate all feedback!',
  },
];
---

<Layout
  title={`${t('nav.faq')} - AI Chat Exporter`}
  description="Frequently asked questions about AI Chat Exporter. Learn how to install, use, and troubleshoot common issues."
  lang={lang}
>
  <!-- Hero -->
  <section class="py-20 text-center">
    <div class="container-custom">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">
        <span class="gradient-text">{t('faq.title')}</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        {t('faq.subtitle')}
      </p>
    </div>
  </section>

  <!-- FAQ Categories -->
  <section class="py-12">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        {faqCategories.map((category) => (
          <div class="mb-12">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <div class="w-8 h-1 bg-accent rounded"></div>
              {category.title}
            </h2>
            <div class="space-y-4">
              {category.questions.map((item) => (
                <details class="group bg-bg-secondary rounded-xl border border-white/5 overflow-hidden">
                  <summary class="flex items-center justify-between p-5 cursor-pointer list-none hover:bg-white/5 transition-colors">
                    <span class="font-medium text-white pr-4">{item.question}</span>
                    <div class="flex-shrink-0 w-6 h-6 rounded-full bg-bg-tertiary flex items-center justify-center group-open:rotate-180 transition-transform duration-200">
                      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </div>
                  </summary>
                  <div class="px-5 pb-5 text-gray-400 text-sm leading-relaxed border-t border-white/5 pt-4">
                    {item.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}

        <!-- Additional FAQs -->
        <div class="mb-12">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <div class="w-8 h-1 bg-accent rounded"></div>
            More Questions
          </h2>
          <div class="space-y-4">
            {additionalFAQs.map((item) => (
              <details class="group bg-bg-secondary rounded-xl border border-white/5 overflow-hidden">
                <summary class="flex items-center justify-between p-5 cursor-pointer list-none hover:bg-white/5 transition-colors">
                  <span class="font-medium text-white pr-4">{item.question}</span>
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-bg-tertiary flex items-center justify-center group-open:rotate-180 transition-transform duration-200">
                    <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </summary>
                <div class="px-5 pb-5 text-gray-400 text-sm leading-relaxed border-t border-white/5 pt-4">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-20 bg-bg-secondary/50">
    <div class="container-custom text-center">
      <h2 class="text-2xl font-bold mb-4">Still have questions?</h2>
      <p class="text-gray-400 mb-8">Can't find the answer you're looking for? Feel free to reach out!</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub Issues
        </a>
        <a
          href="https://twitter.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          Twitter/X
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
