---
import '../styles/global.css';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { type Lang, useTranslations, languages } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  keywords?: string;
}

const { title, description, lang, keywords } = Astro.props;
const t = useTranslations(lang);

// Alternate languages for hreflang
const alternateUrls = Object.keys(languages).map((l) => ({
  lang: l,
  url: `https://aichatexporter.cc/${l}${Astro.url.pathname.replace(/^\/[a-z-]+/, '')}`,
}));
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Canonical URL -->
    <link rel="canonical" href={`https://aichatexporter.cc${Astro.url.pathname}`} />

    <!-- Hreflang tags -->
    {alternateUrls.map(({ lang: l, url }) => (
      <link rel="alternate" hreflang={l} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://aichatexporter.cc/en${Astro.url.pathname.replace(/^\/[a-z-]+/, '')}`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://aichatexporter.cc${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://aichatexporter.cc/og-image.png" />
    <meta property="og:locale" content={lang} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`https://aichatexporter.cc${Astro.url.pathname}`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://aichatexporter.cc/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "AI Chat Exporter",
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Chrome, Edge, Chromium-based browsers",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "ratingCount": "1000"
      }
    })} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NRW5HKRG00"></script>
    <script is:inline set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NRW5HKRG00');
    `} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

